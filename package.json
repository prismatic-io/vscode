{
  "name": "prismatic-io",
  "displayName": "Prismatic.io",
  "publisher": "prismatic",
  "private": true,
  "description": "This extension improves the developer experience around Code-Native Integrations (CNI) by enabling test execution, integration imports, instance configuration (including config variables, debug mode, and trigger payloads), and inspection of execution results—all directly within the IDE.",
  "version": "1.2.1",
  "icon": "resources/prismatic.png",
  "galleryBanner": {
    "color": "#101017",
    "theme": "dark"
  },
  "homepage": "https://github.com/prismatic-io/vscode/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/prismatic-io/vscode"
  },
  "bugs": {
    "url": "https://github.com/prismatic-io/vscode/issues",
    "email": "dev@prismatic.io"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Debuggers",
    "Testing",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "prismatic",
    "integration",
    "cni",
    "code-native integration",
    "debugger",
    "testing",
    "api",
    "workflow",
    "automation"
  ],
  "license": "MIT",
  "type": "module",
  "main": "extension/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Prismatic",
      "properties": {
        "prismatic.prismCliPath": {
          "type": "string",
          "scope": "machine-overridable",
          "default": "",
          "markdownDescription": "Path to the Prism CLI executable. If not specified, the extension will search for `prism` in your system PATH, falling back to npx.\n\nExamples:\n- `/usr/local/bin/prism`\n- `/opt/homebrew/bin/prism`\n- `${userHome}/.npm-global/bin/prism`"
        },
        "prismatic.debugMode": {
          "type": "string",
          "enum": [
            "off",
            "basic",
            "verbose"
          ],
          "default": "off",
          "markdownDescription": "Debug logging level for command execution.\n\n- **off**: No debug logging\n- **basic**: Logs command, working directory, and Node version\n- **verbose**: Logs command, working directory, Node version, and all environment variables"
        }
      }
    },
    "icons": {
      "prismatic-logo": {
        "description": "Prismatic logo",
        "default": {
          "fontPath": "./resources/fonts/prismatic-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "commands": [
      {
        "command": "prismatic.configWizard",
        "title": "Config Wizard",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(settings)"
      },
      {
        "command": "prismatic.me",
        "title": "Me",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.login",
        "title": "Login",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.logout",
        "title": "Logout",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.switchTenant",
        "title": "Switch Tenant",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.integrations.openInBrowser",
        "title": "Open Integration in Browser",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(globe)"
      },
      {
        "command": "prismatic.integrations.import",
        "title": "Import Integration",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "prismatic.integrations.test",
        "title": "Test Integration",
        "category": "Prismatic",
        "enablement": "prismatic.testCommandEnabled && prismatic.workspaceEnabled",
        "icon": "$(play)"
      },
      {
        "command": "prismatic.prismaticUrl",
        "title": "Prismatic URL",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.executionResults.refresh",
        "title": "Refresh Execution Results",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(refresh)"
      },
      {
        "command": "prismatic.executionResults.openLogs",
        "title": "Open Execution Logs",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.executionResults.openStep",
        "title": "Open Step Output",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.integrationDetails.refresh",
        "title": "Refresh Integration Details",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(refresh)"
      },
      {
        "command": "prismatic.integrations.select",
        "title": "Select Integration",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled"
      },
      {
        "command": "prismatic.flows.createPayload",
        "title": "Create Flow Payload",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(add)"
      },
      {
        "command": "prismatic.integrations.revealInExplorer",
        "title": "Reveal in Explorer",
        "category": "Prismatic",
        "enablement": "prismatic.workspaceEnabled",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prismaticIntegrations",
          "title": "Prismatic",
          "icon": "resources/prismatic.svg",
          "when": "prismatic.workspaceEnabled"
        }
      ]
    },
    "views": {
      "prismaticIntegrations": [
        {
          "id": "prismatic.integrationsView",
          "name": "Integrations",
          "icon": "resources/prismatic.svg",
          "contextualTitle": "Prismatic Integrations",
          "when": "prismatic.workspaceEnabled"
        },
        {
          "type": "webview",
          "id": "integrationDetails.webview",
          "name": "Development Instance",
          "icon": "resources/prismatic.svg",
          "contextualTitle": "Development Instance",
          "when": "prismatic.workspaceEnabled"
        },
        {
          "id": "prismatic.flowPayloadsView",
          "name": "Test Payloads",
          "icon": "resources/prismatic.svg",
          "contextualTitle": "Flow Test Payloads",
          "when": "prismatic.workspaceEnabled"
        },
        {
          "id": "prismatic.executionResultsView",
          "name": "Execution Results",
          "icon": "resources/prismatic.svg",
          "contextualTitle": "Execution Results",
          "when": "prismatic.workspaceEnabled"
        }
      ]
    },
    "languages": [
      {
        "id": "prismatic-log",
        "aliases": ["Prismatic Log"],
        "extensions": [],
        "configuration": "./resources/prismatic-log-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "prismatic-log",
        "scopeName": "source.prismatic-log",
        "path": "./resources/prismatic-log.tmLanguage.json"
      }
    ],
    "viewsWelcome": [
      {
        "view": "prismatic.integrationsView",
        "contents": "No integrations detected.\n\n[Learn more about Prismatic integrations](https://prismatic.io/docs)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "prismatic.executionResults.openLogs",
          "when": "false"
        },
        {
          "command": "prismatic.executionResults.openStep",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "prismatic.integrations.test",
          "when": "view == prismatic.executionResultsView && prismatic.testCommandEnabled && prismatic.workspaceEnabled",
          "group": "navigation@1"
        },
        {
          "command": "prismatic.executionResults.refresh",
          "when": "view == prismatic.executionResultsView && prismatic.workspaceEnabled",
          "group": "navigation@2"
        },
        {
          "command": "prismatic.integrationDetails.refresh",
          "when": "view == integrationDetails.webview && prismatic.workspaceEnabled",
          "group": "navigation@1"
        },
        {
          "command": "prismatic.configWizard",
          "when": "view == integrationDetails.webview && prismatic.workspaceEnabled",
          "group": "navigation@2"
        },
        {
          "command": "prismatic.integrations.import",
          "when": "view == integrationDetails.webview && prismatic.workspaceEnabled",
          "group": "navigation@3"
        },
        {
          "command": "prismatic.integrations.openInBrowser",
          "when": "view == integrationDetails.webview && prismatic.workspaceEnabled",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "prismatic.integrations.select",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem",
          "group": "navigation@1"
        },
        {
          "command": "prismatic.integrations.test",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active && prismatic.testCommandEnabled",
          "group": "navigation@2"
        },
        {
          "command": "prismatic.integrations.test",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active && prismatic.testCommandEnabled",
          "group": "inline@1"
        },
        {
          "command": "prismatic.integrations.import",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active",
          "group": "1_integration@1"
        },
        {
          "command": "prismatic.integrationDetails.refresh",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active",
          "group": "1_integration@2"
        },
        {
          "command": "prismatic.integrations.openInBrowser",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active",
          "group": "2_navigate@1"
        },
        {
          "command": "prismatic.integrations.revealInExplorer",
          "when": "view == prismatic.integrationsView && viewItem =~ /^integrationItem/",
          "group": "2_navigate@2"
        },
        {
          "command": "prismatic.integrations.revealInExplorer",
          "when": "view == prismatic.integrationsView && viewItem =~ /^integrationItem/",
          "group": "inline@2"
        },
        {
          "command": "prismatic.configWizard",
          "when": "view == prismatic.integrationsView && viewItem == integrationItem.active",
          "group": "3_config@1"
        },
        {
          "command": "prismatic.integrations.test",
          "when": "view == prismatic.flowPayloadsView && viewItem == flowItem",
          "group": "inline@1"
        },
        {
          "command": "prismatic.flows.createPayload",
          "when": "view == prismatic.flowPayloadsView && viewItem == flowItem",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build:icons": "fantasticon",
    "build:dev": "bun run build.ts",
    "build:prod": "bun run build.ts --production",
    "build": "bun run check-types && bun run build:prod",
    "vscode:prepublish": "bun run build",
    "watch": "bun run build.ts --watch",
    "package": "vsce package",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "check": "biome check .",
    "check:fix": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "bun run build:dev && tsc -p tsconfig.integration.json && echo '{\"type\":\"commonjs\"}' > out/package.json && vscode-test",
    "publish:vsce": "vsce publish --packagePath *.vsix",
    "publish:ovsx": "ovsx publish *.vsix"
  },
  "dependencies": {
    "@iconscout/react-unicons": "^2.2.5",
    "@msgpack/msgpack": "^3.1.2",
    "@xstate/react": "^6.1.0",
    "date-fns": "^4.1.0",
    "package-manager-detector": "^1.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.1.17",
    "tinyexec": "^1.1.1",
    "xstate": "^5.19.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/stylis": "^4.2.7",
    "@types/vscode": "1.116.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.28.0",
    "fantasticon": "^4.1.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "trustedDependencies": [
    "@vscode/vsce-sign",
    "esbuild",
    "ttf2woff2"
  ]
}
