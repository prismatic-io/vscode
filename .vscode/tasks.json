{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build:dev",
      "type": "npm",
      "script": "build:dev",
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "npm: watch",
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    },
    {
      "label": "npm: build:prod",
      "type": "npm",
      "script": "build:prod",
      "problemMatcher": "$tsc",
      "group": "build",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "get-npm-global-bin",
      "type": "shell",
      "command": "npm config get prefix",
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "prepare-dev-environment",
      "dependsOn": ["get-npm-global-bin", "npm: build:dev"],
      "dependsOrder": "sequence"
    },
    {
      "label": "scaffold-cni-workspace",
      "type": "shell",
      "command": "test -d test-workspaces/cni-workspace/.spectral || (cd test-workspaces && prism integrations:init cni-workspace)",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build:dev + scaffold-cni",
      "dependsOn": ["npm: build:dev", "scaffold-cni-workspace"],
      "dependsOrder": "parallel"
    },
    {
      "label": "scaffold-monorepo-workspace",
      "type": "shell",
      "command": "cd test-workspaces/monorepo-workspace && for name in integration-alpha integration-beta integration-gamma; do test -d \"$name/.spectral\" || prism integrations:init \"$name\"; done",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build:dev + scaffold-monorepo",
      "dependsOn": ["npm: build:dev", "scaffold-monorepo-workspace"],
      "dependsOrder": "parallel"
    }
  ]
}
